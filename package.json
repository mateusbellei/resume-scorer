{
  "name": "resume-scorer",
  "version": "1.0.0",
  "description": "Automatização para ler currículos (PDF/DOCX), analisar conteúdo e dar score para vaga Nuxt/Vue/TypeScript/Tailwind",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "score": "npm run build && node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "resume",
    "nuxt",
    "vue",
    "scoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
